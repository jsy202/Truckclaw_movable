# ── Leader Rotation 시나리오 (단일 군집) ──────────────────────────────────────

# truck0 (현재 선두) OpenClaw 봇
TRUCK0_DISCORD_BOT_TOKEN=your_truck0_discord_bot_token_here
TRUCK0_OPENCLAW_GATEWAY_TOKEN=your_truck0_gateway_token_here
TRUCK0_CONFIG_DIR=./.openclaw-truck0

# truck1 (다음 선두) OpenClaw 봇 — 선두 교체 시 자동 기동
TRUCK1_DISCORD_BOT_TOKEN=your_truck1_discord_bot_token_here
TRUCK1_OPENCLAW_GATEWAY_TOKEN=your_truck1_gateway_token_here
TRUCK1_CONFIG_DIR=./.openclaw-truck1

# ── OpenClaw 이미지 ───────────────────────────────────────────────────────────
OPENCLAW_IMAGE=openclaw:local

# ── OpenAI (선택) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 두 군집 시나리오 (legacy — docker compose --profile two-platoon) ───────────
PLATOON_A_DISCORD_BOT_TOKEN=your_discord_bot_token_here
PLATOON_A_OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
PLATOON_B_DISCORD_BOT_TOKEN=your_discord_bot_token_here
PLATOON_B_OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
PLATOON_A_CONFIG_DIR=./.openclaw-platoon-a
PLATOON_B_CONFIG_DIR=./.openclaw-platoon-b
